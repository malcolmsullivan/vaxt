# ── Secrets (NEVER commit) ──────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Python ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.venv/
venv/
.ruff_cache/

# ── Local tooling ───────────────────────────────────────────────────────
.claude/settings.local.json
.DS_Store

# ── Wheel build artifacts (vaxt-mcp bundling) ───────────────────────────
# The build hook (packages/vaxt/hatch_build.py) stages the warehouse + fingerprint
# into the wheel at build time. These are build artifacts, never committed — the
# canonical warehouse stays the single source of truth at data/… above.
packages/vaxt/.hatch-build/
packages/vaxt/src/vaxt_mcp/data/

# ── Runtime data ────────────────────────────────────────────────────────
# We COMMIT a prebuilt heritage-grain.duckdb (27 tables, ~9 MB) so CI runs the
# tests offline and green. Everything else here (fetched ETL CSVs, the FAOSTAT
# zip, the DuckDB WAL) is a runtime artifact and stays ignored.
data/datasets/heritage-grain/*
!data/datasets/heritage-grain/heritage-grain.duckdb
