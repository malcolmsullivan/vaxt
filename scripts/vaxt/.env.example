# VAXT Airtable + Notion Integration
# Copy to .env and fill in values. NEVER commit .env.

# Airtable Personal Access Token (create at airtable.com/create/tokens)
# Scopes needed: data.records:read, data.records:write, schema.bases:read, schema.bases:write
VAXT_AIRTABLE_PAT=patXXXXXXXXXXXXXX

# Alias for Airtable MCP server (.mcp.json reads this)
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX

# Airtable Base ID (from URL: airtable.com/appXXXXXXX/...)
VAXT_AIRTABLE_BASE_ID=appgv7zVxZnT2q9BX

# Notion Internal Integration Token (create at notion.so/my-integrations)
# Must have access to the VAXT Knowledge Base page
VAXT_NOTION_TOKEN=ntn_XXXXXXXXXXXXXXXXXXXX

# Notion VAXT KB root page ID
VAXT_NOTION_KB_PAGE_ID=318c2b5ee82f81bb95dcd842992c3a05

# Output directory (gitignored)
VAXT_OUTPUT_DIR=data/datasets/heritage-grain
