# Keep the build context small and the image clean.
.git
.github
.claude
**/__pycache__
**/*.pyc
**/*.egg-info
.pytest_cache
.ruff_cache
.venv
venv
docs
tests
.playwright-mcp
# Runtime ETL artifacts — the committed heritage-grain.duckdb is NOT ignored
# (the leading data/ rule would catch it), so re-include it explicitly.
data/datasets/heritage-grain/*
!data/datasets/heritage-grain/heritage-grain.duckdb
